# Copy this file to .env and add your API keys
# Do NOT commit your actual .env file to GitHub

# Select your AI provider (gemini or claude)
AI="gemini"

# Maximum number of successful applications per run
MAX_APPLICATIONS="3"

# Profile to use from the profiles/ directory (filename without .yaml extension)
PROFILE="dummy_profile"

GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL="gemini-2.5-flash"

# Optional: Use Claude instead of Gemini
ANTHROPIC_API_KEY="your_anthropic_api_key_here"
CLAUDE_MODEL="claude-sonnet-4-5"
